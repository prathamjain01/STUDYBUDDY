# Server Configuration
PORT=3000

# Database Connection (MongoDB)
# If experiencing DNS/SRV errors (e.g. ECONNREFUSED), use the standard multi-host mongodb:// format instead of mongodb+srv://
MONGO_URL=mongodb://<username>:<password>@<host1>:<port>,<host2>:<port>/<dbname>?ssl=true&replicaSet=<replicaset>&authSource=admin&retryWrites=true&w=majority

# Cloudinary Credentials (for PDF and Thumbnail storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
